p({
  "class": "foam.core.boot.CSpec",
  "name": "{subDomain}DAO",
  "description": "",
  "serve": true,
  "authenticate": true,
  "keywords": [ "{subDomain}" ],
  "serviceScript": """
    return new foam.dao.EasyDAO.Builder(x)
      .setOf({tld}.{domain}.{SubDomain}.getOwnClassInfo())
      .setPm(true)
      .setFuid(true)
      .setAuthorize(false)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .build();
  """,
  "client": `{"of":"{tld}.{domain}.{SubDomain}"}`
})
