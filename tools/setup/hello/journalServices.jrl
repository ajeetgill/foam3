p({
  "class": "foam.core.boot.CSpec",
  "name": "{model}DAO",
  "description": "",
  "serve": true,
  "authenticate": true,
  "keywords": [ "{model}" ],
  "serviceScript": """
    return new foam.dao.EasyDAO.Builder(x)
      .setOf({package}.{Model}.getOwnClassInfo())
      .setPm(true)
      .setSeqNo(true)
      .setAuthorize(false)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .build();
  """,
  "client": `{"of":"{package}.{Model}"}`
})
