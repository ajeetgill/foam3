})

p({
  class: "foam.core.boot.CSpec",
  name: "dugLoopbackDAO",
  serve: true,
  serviceScript: """
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.dig.DUGLoopback.getOwnClassInfo())
      .setFuid(true)
      .setFixedSize(new foam.dao.FixedSizeDAO.Builder(x)
        .setComparator(foam.mlang.MLang.DESC(foam.core.dig.DUGLoopback.TIMESTAMP))
        .setSize(100)
        .build())
      .build()
      .orderBy(foam.mlang.MLang.DESC(foam.core.dig.DUGLoopback.TIMESTAMP));
  """,
  "client": """
    {
      "of":"foam.core.dig.DUGLoopback"
    }
  """
})

p({
  class: "foam.core.boot.CSpec",
  name: "dugLoopback",
  description: "DUG endpoint for testing. Set DUGRule url to loopback",
  authenticate: false,
  parameters: true,
  serviceClass: "foam.core.dig.DUGLoopbackWebAgent"
})


p({
  "class": "foam.core.boot.CSpec",
  "name": "userHistoryDAO",
  "description": "DAO containing any modifications made to users",
  "serve": true,
  "lazy": true,
  "authNotes": "Protected by service-level access control. This service requires the 'service.userHistoryDAO' permission to access.",
  "serviceScript":
  """
    return new foam.dao.EasyDAO.Builder(x)
      .setAuthorize(false)
      .setSeqNo(true)
      .setSeqPropertyName("seqNo")
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("userHistory")
      .setOf(foam.dao.history.HistoryRecord.getOwnClassInfo())
      .build()
      .addPropertyIndex(new foam.lang.PropertyInfo[] { foam.dao.history.HistoryRecord.OBJECT_ID })
      .orderBy(foam.mlang.MLang.DESC(foam.dao.history.HistoryRecord.TIMESTAMP));
  """,
  "client":
  """
    { "of": "foam.dao.history.HistoryRecord" }
  """
})
p({
  "class": "foam.core.boot.CSpec",
  "name": "historyRecordServiceTestUserDAO",
  "serve": false,
  "serviceScript": """
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.auth.User.getOwnClassInfo())
      .setPm(true)
      .setFuid(true)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("users")
      .setDecorator(new foam.dao.history.HistoryDAO(x, "userHistoryDAO", new foam.dao.NullDAO.Builder(x).setOf(foam.core.auth.User.getOwnClassInfo()).build()))
      .build()
      .addPropertyIndex(new foam.lang.PropertyInfo[] { foam.core.auth.User.REFERRAL_CODE });
  """
})
p({"class":"foam.core.boot.CSpec", "name":"serializationTestEchoService", "boxClass": "foam.core.test.EchoServiceSkeleton",  "serve":true, "serviceClass":"foam.core.test.SerializationTestEchoService", "client":"{\"class\":\"foam.core.test.ClientEchoService\",\"delegate\":{\"class\":\"foam.box.SessionClientBox\",\"delegate\":{\"class\":\"foam.box.HTTPBox\",\"method\":\"POST\",\"url\":\"service/serializationTestEchoService\"}}}"})
