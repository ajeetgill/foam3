// settings
p({
  "class":"foam.core.menu.Menu",
  "id":"set-password",
  "label":"Change Password",
  "handler":{
    "class":"foam.core.menu.ViewMenu",
    "view":{
      class: 'foam.core.auth.ChangePasswordView',
      modelOf: 'foam.core.auth.UpdatePassword',
      showHeader: false,
      isHorizontal: true,
      popup: false
    }
  },
  "order":3,
  "parent":"settings"
})

p({
  "class":"foam.core.menu.Menu",
  "id":"sign-out",
  "label":"Sign Out",
  "handler":{
    "class":"foam.core.menu.ViewMenu","view":{
      "class":"foam.core.auth.SignOutView"
    }
  },
  "order":10000,
  "parent":"settings"
})

// hidden
p({"class":"foam.core.menu.Menu","id":"dashboard-demo","handler":{"class":"foam.core.menu.ViewMenu","view":{"class":"foam.core.dashboard.Demo"}},"parent":"hidden"})
p({
  "class":"foam.core.menu.Menu",
  "id":"notifications",
  "label":"Notifications",
  "handler": {
    "class": "foam.core.menu.DAOMenu2",
    "config": {
      "class": "foam.comics.v2.DAOControllerConfig",
      "daoKey": "myNotificationDAO",
      "browseTitle": "Notifications",
      "createPredicate":{"class":"foam.mlang.predicate.False"},
      "editPredicate":{"class":"foam.mlang.predicate.False"},
      "deletePredicate":{"class":"foam.mlang.predicate.False"},
      "hideQueryBar": true,
      "summaryView":{
        "class":"foam.u2.GroupingDAOList",
        "showEmptyMessage": true,
        "order":{
          "class": "foam.mlang.order.Desc",
          "arg1": {
            "class": "__Property__",
            "forClass_": "foam.core.notification.Notification",
            "name": "created"
          }
        },
        "rowView":{
          "class":"foam.core.notification.NotificationRowView"
        },
        "groupExpr":{
          "class":"foam.mlang.expr.DateTimeGroupingExpr",
          "dateGroupType":0,
          "dateGroups":[
            {
              "class":"foam.mlang.expr.DateGrouping",
              "name":"Today",
              "high":1
            },
            {
              "class":"foam.mlang.expr.DateGrouping",
              "name":"Yesterday",
              "low":1,
              "high":2
            },
            {
              "class":"foam.mlang.expr.DateGrouping",
              "name":"Older",
              "low":2
            }
          ]
        }
      }
    }
  },
  "parent":"user-config"
})
