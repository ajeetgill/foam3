// admin
p({"class":"foam.core.menu.Menu","id":"admin","label":"Admin","handler":{"class":"foam.core.menu.SubMenu"},"parent":""})
p({
  class: "foam.core.menu.Menu",
  id: "admin.dashboard",
  keywords: ["dashboard","cron","alarm","er","health"],
  label: "Ops Dashboard",
  themeIcon: "dashboard",
  handler: {
    class: "foam.core.menu.ViewMenu",
    view: {
      class: "foam.dashboard.view.DashboardView",
      title: "Ops Dashboard",
      main: true,
      widgets: {
        "foam.core.cron.cronJobWidget": { column: 6 },
        "foam.core.alarming.alarmWidget": { column: 6 },
        "foam.core.er.eventRecordWidget": { column: 6 },
        "foam.core.medusa.medusaHealthWidget": { column: 6 },
        "foam.core.logger.logMessageWidget": { column: 12 },
        "foam.core.medusa.medusaIndexChartWidget": { column: 12 }
      }
    }
  },
  parent:"admin"
})
