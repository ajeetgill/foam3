  cSpec: "approvalRequestDAO",
  compactible: true,
  sink: {
    class: "foam.core.approval.ApprovalRequestCompactionSink",
    predicate: {
      class: "foam.mlang.predicate.FScriptPredicate",
      query: 'status == foam.core.approval.ApprovalStatus.REQUESTED'
    }
  }
})
