console.clear();

foam.QA2({
  package: 'com.example',
  name: 'RestaurantPicker',

  properties: [
    // Inputs
    { class: 'Boolean', name: 'allergicToSeafood' },
    { class: 'Boolean', name: 'allergicToWheat' },
    { class: 'Float',   name: 'priceLimit' },

    // Outputs
    { class: 'String',  name: 'name' }
  ],

  questions: [
    { name: 'cuisine',
      prompt: 'What type of cuisine are you in the mood for?',
      choices: ['Asian', 'Italian', 'American', 'Mexican'] },

    { name: 'spicy',
      prompt: 'Do you enjoy spicy food?' },

    { name: 'vegetarian',
      prompt: 'Are you looking for a vegetarian option?' },

    { name: 'dineIn',
      prompt: 'Would you like to dine in?' }
  ],

  outcomes: [
    { name: 'Sushi Place',
      predicate: 'allergicToSeafood IS FALSE AND cuisine=Asian AND spicy=FALSE AND priceLimit>=30' },

    { name: 'Thai Restaurant',
      predicate: 'cuisine = Asian AND spicy = TRUE AND priceLimit >= 20' },

    { name: 'Noodle Bar',
      predicate: 'allergicToWheat IS FALSE AND cuisine = Asian AND priceLimit < 20' },

    { name: 'Pizza Trattoria',
      predicate: 'allergicToWheat IS FALSE AND cuisine = Italian AND priceLimit < 25' },

    { name: 'Fine Italian',
      predicate: 'cuisine = Italian AND priceLimit >= 40' },

    { name: 'Burger Joint',
      predicate: 'allergicToWheat IS FALSE AND cuisine = American AND vegetarian = FALSE AND priceLimit < 20' },

    { name: 'Steakhouse',
      predicate: 'cuisine = American AND vegetarian = FALSE AND priceLimit >= 30' },

    { name: 'Veggie Grill',
      predicate: 'cuisine = American AND vegetarian = TRUE' },

    { name: 'Taco Truck',
      predicate: 'cuisine = Mexican AND spicy = TRUE AND dineIn = FALSE AND priceLimit < 15' },

    { name: 'Burrito Bar',
      predicate: 'allergicToWheat IS FALSE AND cuisine = Mexican AND priceLimit < 20' },

    { name: 'Upscale Mexican',
      predicate: 'cuisine = Mexican AND priceLimit >= 30' }
  ]
});


    var picker = com.example.RestaurantPicker.create({
      allergicToSeafood: false,
      priceLimit: 1000
    });

    console.log('Picket:', picker);
    console.log('Choices:', picker.getCandidates());

    // Properties are resolved immediately, narrowing candidates.
    // Then loop: ask questions, set answers, converge.
    var q = picker.selectNextQuestion();   // -> { name: 'cuisine', ... }
    console.log('Next Question:', q.name);
    picker.cuisine = 'Asian';

    console.log('Choices:', picker.getCandidates());

    q = picker.selectNextQuestion();       // -> { name: 'spicy', ... }
    console.log('Next Question:', q.name);
    picker.spicy = 'TRUE';

    console.log('Choices:', picker.getCandidates());
    var results = picker.getCandidates();
    picker.applyOutcome(results[0]);       // sets picker.name = 'Thai Restaurant'
    console.log(picker.name);
