p({
  "class": "foam.core.boot.CSpec",
  "name": "dig",
  "description": "Data Integration Gateway",
  "parameters": true,
  "serviceScript": "return new foam.core.dig.DigWebAgent()"
})

p({
  "class":"foam.core.boot.CSpec",
  "name":"digDAO",
  "description": "Data Integration Gateway",
  "serve":true,
  "serviceScript":
  """
  return new foam.dao.EasyDAO.Builder(x)
    .setPm(true)
    .setGuid(true)
    .setOf(foam.core.dig.DIG.getOwnClassInfo())
    .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
    .setJournalName("digs")
    .build();
  """,
  "client":"{\"of\":\"foam.core.dig.DIG\",\"decorators\": [{\"class\":\"foam.core.fs.FileDAODecorator\"},{\"class\":\"foam.core.fs.FileArrayDAODecorator\"}]}"
})

p({
  "class":"foam.core.boot.CSpec",
  "name":"dugDigestConfigDAO",
  "serve":true,
  "serviceScript":
  """
  return new foam.dao.EasyDAO.Builder(x)
    .setPm(true)
    .setOf(foam.core.dig.DUGDigestConfig.getOwnClassInfo())
    .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
    .setJournalName("dugDigestConfigs")
    .build();
  """,
  "client":
  """
    {
      "of":"foam.core.dig.DUGDigestConfig"
    }
  """
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "sugar",
  "lazy": true,
  "serve": false,
  "authenticate": false,
  "parameters": true,
  "serviceScript": "return new foam.core.dig.SugarWebAgent()"
})

p({
  "class":"foam.core.boot.CSpec",
  "name":"sugarDAO",
  "serve":true,
  "serviceScript":"""
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.dig.SUGAR.getOwnClassInfo())
      .setGuid(true)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("sugars")
      .setPm(true)
      .build();
  """,
  "client":"{\"of\":\"foam.core.dig.SUGAR\"}"
})
