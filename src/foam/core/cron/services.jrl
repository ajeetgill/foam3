p({
  "class": "foam.core.boot.CSpec",
  "name": "nextDateService",
  "description": "A service that returns the next date of a schedule",
  "serve": true,
  "authenticate": false,
  "serviceClass": "foam.core.cron.NextDate",
  "boxClass": "foam.core.cron.NextDateServiceSkeleton",
  "client": """
    {
      "class": "foam.core.cron.ClientNextDateService",
      "delegate": {
          "class": "foam.box.HTTPBox",
          "url": "service/nextDateService"
        }
    }
  """
})
