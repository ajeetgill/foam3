p({
  "class": "foam.core.boot.CSpec",
  "name": "version",
  "lazy": false,
  "authenticate": false,
  "serviceClass": "foam.core.app.VersionWebAgent"
})

p({
  "class":"foam.core.boot.CSpec",
  "name":"healthDAO",
  "serve":true,
  "serviceScript": """
  return new foam.dao.EasyDAO.Builder(x)
    .setOf(foam.core.app.Health.getOwnClassInfo())
    .setCluster(false)
    .setSaf(false)
    .setDecorator(new foam.core.app.HealthRemoveDAO.Builder(x)
      .setDelegate(new foam.dao.NullDAO(x, foam.core.app.Health.getOwnClassInfo()))
      .build())
    .build();
  """,
  "client":"""
  {
    "of":"foam.core.app.Health"
  }
  """
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "health",
  "lazy": false,
  "authenticate": false,
  "parameters": true,
  "serviceClass": "foam.core.app.HealthWebAgent"
})

p({
  class: "foam.core.boot.CSpec",
  name: "Health",
  description: "Health Factory",
  authenticate: false,
  pm: false,
  service: {
    class: "foam.core.app.HealthFactory"
  }
})

p({
  "class":"foam.core.boot.CSpec",
  "name":"healthSupport",
  "lazy":false,
  "service": {
    "class": "foam.core.app.HealthSupport"
  }
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "healthHeartbeatService",
  "lazy": false,
  "service": {
    class: "foam.core.app.HealthHeartbeatService",
    multicastAddress: "230.22.41.0",
    port: 52241
  }
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "healthHeartbeatMonitor",
  "lazy": false,
  "service": {
    class: "foam.core.app.HealthHeartbeatMonitor",
  }
})

p({
  "class":"foam.core.boot.CSpec",
  "name":"appDownloadBadgeService",
  "serve":true,
  "lazyClient": false,
  "authenticate":false,
  "client":"{ \"class\": \"foam.core.app.AppDownloadBadgeService\" }"
})

