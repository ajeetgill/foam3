p({
  "class":"foam.core.reflow.ai.LLMCommand",
  "id": "llm",
  "permissionRequired": true,
  "description": "Issue a direct LLM query."
})
p({
  "class":"foam.core.reflow.ai.AgentCommand",
  "id": "agent",
  "dryRun": false,
  "permissionRequired": true,
  "description": "Issue a request to an LLM agent to execute FLOW commands."
})
