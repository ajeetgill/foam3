p({
  "class":"foam.core.reflow.ai.AgentCommand",
  "id": "plan",
  "dryRun": true,
  "permissionRequired": true,
  "description": "Issue a request to an LLM agent to plan FLOW commands."
})
p({
  "class":"foam.core.reflow.cmd.Command",
  "id": "propose",
  "description": "Propose a command for execution",
  "permissionRequired": true,
  "script": "debugger;addValue(foam.core.reflow.ai.Propose.create({command: args.join(' ')}, this));"
})
