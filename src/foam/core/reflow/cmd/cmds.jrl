p({
  "class":"foam.core.reflow.cmd.Command",
  "id": "doc",
  "description": "Insert Document",
  "script": "addValue(foam.core.reflow.Doc.create({richText: args.join(' ')}, this));"
})
p({
  "class":"foam.core.reflow.cmd.Command",
  "id": "upload",
  "description": "Upload Data",
  linkable: false,
  "script": """
    var scope = this.__context__.scope;
    if ( foam.String.isInstance(args[0]) && scope[args[0]] ) args[0] = scope[args[0]];
    else if ( foam.String.isInstance(args[0]) && scope[args[0] + 'DAO'] ) args[0] = scope[args[0] + 'DAO'];
    if ( foam.dao.DAO.isInstance(args[0]) ) {
      this.out.add(foam.core.reflow.Upload.create({dao: args[0]}, this));
    } else {
      this.out.add(foam.core.reflow.Upload.create({daoKey: args[0]}, this));
    }
  """
})
p({
  "class":"foam.core.reflow.cmd.Command",
  "id": "script",
  "description": "Create a Script",
  "script": """
    addValue(foam.core.reflow.Script.create({}, this), true);
  """
})
p({
  "class":"foam.core.reflow.cmd.Command",
  "id": "fetch",
  "description": "Fetch a file from a URL",
  "script": """
    addValue(foam.core.reflow.XHR.create({url: args[0]}, this));
  """,
  permissionRequired: true
})
