p({
  "class":"foam.core.reflow.cmd.Command",
  "id": "testresults",
  "description": "Insert an Test Results Summary",
  "script": """
    var results = foam.core.reflow.float.TestResults.create({}, this);
    this.block.value = results;
    this.block.flowName = 'testResults';
    this.out.tag(foam.core.reflow.float.TestResultsView, {data: results});
  """,
  permissionRequired: true
})

p({
  "class":"foam.core.reflow.cmd.Command",
  "id": "test",
  "description": "Insert an Expectation Test",
  "help": "",
  "script": """
    var results = this.__context__.scope.testResults;

    // If no testResults, then create one first then rerun this command
    if ( ! results ) {
       results = foam.core.reflow.float.TestResults.create({}, this);
       this.block.value    = results;
       this.block.flowName = 'testResults';
       this.block.cmd      = 'testresults';
       this.out.tag(foam.core.reflow.float.TestResultsView, {data: results});

       // A delay of 100ms doesn't work, so we wait 400ms, I don't know why. KGR
       setTimeout(() => {
         this.__context__.eval_(`test('${args[0]}', '${args[1] || ''}')`);
       }, 400);
    } else {
      var test = foam.core.reflow.float.Test.create({
        received: args[0],
        description: args[1] || ''}, this);
      test.accept();

      results.report(test);
      this.block.value = test;
      this.out.tag(foam.core.reflow.float.TestView, {data: test});
      this.block.treeRowRenderer = function(e) {
        e.start().style({color: test.status$.map(s => s ? 'green' : 'red')}).add(this.flowName);
      };

      // Listen for block detach to clean up the test from testResults
      this.block.onDetach(() => results?.dao?.remove(test));
    }
  """,
  permissionRequired: true
})
