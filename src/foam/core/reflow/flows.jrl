p({class:"foam.core.reflow.Flow",name:"FLOAT: Calculations",version:18,script:"[\n\t{\n\t\t\n\t\t\"flowName\": \"h11\",\n\t\t\"cmd\": \"h1 Calculations\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.Header\",\n\t\t\t\"text\": \"Calculations\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"testResults\",\n\t\t\"cmd\": \"testresults\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.TestResults\",\n\t\t\t\"total\": 6\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"countries1\",\n\t\t\"cmd\": \"dao country\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Countries\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.TableDAOAgent\",\n\t\t\t\t\"columns\": [\n\t\t\t\t\t\n\t\t\t\t]\n\t\t\t},\n\t\t\t\"rowCount\": 245\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"transform1\",\n\t\t\"cmd\": \"transform(\\\"countries1.filteredDAO\\\")\",\n\t\t\"value\": {\n\t\t\t\"class\": \"com.paytic.flow.transform.Transform\",\n\t\t\t\"daoKey\": \"countries1.filteredDAO\",\n\t\t\t\"calculations\": [\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t\t\"name\": \"double\",\n\t\t\t\t\t\"expression\": \"parseInt(this.code,36)/10\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"testdata\",\n\t\t\"cmd\": \"dao(transform1.data, 'transform1data1')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test Data\",\n\t\t\t\"limit\": 10,\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.CellsDAOAgent\"\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 4\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test1data\",\n\t\t\"cmd\": \"dao(testdata.limitedDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test 1 Data\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.SumDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.tmp.TransformedCountry\",\n\t\t\t\t\t\"name\": \"double\"\n\t\t\t\t}\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 1\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test1\",\n\t\t\"cmd\": \"test(test1data.value.value, 'Verify Sum Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Sum Operation for Table Column\",\n\t\t\t\"expected\": \"379.2\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test2data\",\n\t\t\"cmd\": \"dao(testdata.limitedDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test 2 Data\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.MinDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.tmp.TransformedCountry\",\n\t\t\t\t\t\"name\": \"double\"\n\t\t\t\t}\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 1\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test2\",\n\t\t\"cmd\": \"test(test2data.value.value, 'Verify Min Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Min Operation for Table Column\",\n\t\t\t\"expected\": \"37.3\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test3data\",\n\t\t\"cmd\": \"dao(testdata.limitedDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test 3 Data\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.DuplicateDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.core.auth.Country\",\n\t\t\t\t\t\"name\": \"phoneCode\"\n\t\t\t\t},\n\t\t\t\t\"sink\": {\n\t\t\t\t\t\"class\": \"foam.core.reflow.CSVDAOAgent\"\n\t\t\t\t}\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 1\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test3\",\n\t\t\"cmd\": \"test(test3data.value, 'Verify Duplicate Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Duplicate Operation for Table Column\",\n\t\t\t\"expected\": \"something\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"a1\",\n\t\t\"cmd\": \"console.log(test3data.value)\"\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test4data\",\n\t\t\"cmd\": \"dao(testdata.limitedDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test 4 Data\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.AvgDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.tmp.TransformedCountry\",\n\t\t\t\t\t\"name\": \"double\"\n\t\t\t\t}\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 1\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test4\",\n\t\t\"cmd\": \"test(test4data.value.value, 'Verify Avg Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Avg Operation for Table Column\",\n\t\t\t\"expected\": \"37.92\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test5data\",\n\t\t\"cmd\": \"dao regions\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Regions\",\n\t\t\t\"limit\": 0,\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.CountDAOAgent\"\n\t\t\t},\n\t\t\t\"rowCount\": 1061,\n\t\t\t\"version\": 2\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test5\",\n\t\t\"cmd\": \"test(test5data.value.value, 'Verify Count Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Count Operation for Table Column\",\n\t\t\t\"expected\": \"1061\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test6data\",\n\t\t\"cmd\": \"dao(testdata.limitedDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test 6 Data\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.MaxDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.tmp.TransformedCountry\",\n\t\t\t\t\t\"name\": \"double\"\n\t\t\t\t}\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 1\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test6\",\n\t\t\"cmd\": \"test(test6data.value.value, 'Verify Max Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Max Operation for Table Column\",\n\t\t\t\"expected\": \"38.6\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"h12\",\n\t\t\"cmd\": \"h1(\\\"TODO: Fix Duplicate and Count.\\\")\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.Header\",\n\t\t\t\"text\": \"TODO: Fix Duplicate.\",\n\t\t\t\"color\": \"red\"\n\t\t}\n\t}\n]",lastModified:1751463522567})