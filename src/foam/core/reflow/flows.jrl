p({class:"foam.core.reflow.Flow",name:"FLOAT: Calculations",version:23,script:"[\n\t{\n\t\t\n\t\t\"flowName\": \"h11\",\n\t\t\"cmd\": \"h1 Calculations\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.Header\",\n\t\t\t\"text\": \"Calculations\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"testResults\",\n\t\t\"cmd\": \"testresults\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.TestResults\",\n\t\t\t\"total\": 6\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"countries1\",\n\t\t\"cmd\": \"dao country\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Countries\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.TableDAOAgent\",\n\t\t\t\t\"columns\": [\n\t\t\t\t\t\n\t\t\t\t]\n\t\t\t},\n\t\t\t\"rowCount\": 245\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"transform1\",\n\t\t\"cmd\": \"transform(\\\"countries1.filteredDAO\\\")\",\n\t\t\"value\": {\n\t\t\t\"class\": \"com.paytic.flow.transform.Transform\",\n\t\t\t\"daoKey\": \"countries1.filteredDAO\",\n\t\t\t\"calculations\": [\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t\t\"name\": \"double\",\n\t\t\t\t\t\"expression\": \"parseInt(this.code,36)/10\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"testdata\",\n\t\t\"cmd\": \"dao(transform1.data, 'transform1data1')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test Data\",\n\t\t\t\"limit\": 10,\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.CellsDAOAgent\"\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 4\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test1data\",\n\t\t\"cmd\": \"dao(testdata.limitedDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test 1 Data\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.SumDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.tmp.TransformedCountry\",\n\t\t\t\t\t\"name\": \"double\"\n\t\t\t\t}\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 1\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test1\",\n\t\t\"cmd\": \"test(test1data.value.value, 'Verify Sum Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Sum Operation for Table Column\",\n\t\t\t\"expected\": \"379.2\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test2data\",\n\t\t\"cmd\": \"dao(testdata.limitedDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test 2 Data\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.MinDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.tmp.TransformedCountry\",\n\t\t\t\t\t\"name\": \"double\"\n\t\t\t\t}\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 1\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test2\",\n\t\t\"cmd\": \"test(test2data.value.value, 'Verify Min Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Min Operation for Table Column\",\n\t\t\t\"expected\": \"37.3\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test3data\",\n\t\t\"cmd\": \"dao(testdata.limitedDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test 3 Data\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.DuplicateDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.core.auth.Country\",\n\t\t\t\t\t\"name\": \"phoneCode\"\n\t\t\t\t},\n\t\t\t\t\"sink\": {\n\t\t\t\t\t\"class\": \"foam.core.reflow.JSONDAOAgent\"\n\t\t\t\t}\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 4\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test3\",\n\t\t\"cmd\": \"test(test3data.value, 'Verify Duplicate Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Duplicate Operation for Table Column\",\n\t\t\t\"expected\": \"[\\u000a\\u0009{\\u000a\\u0009\\u0009\\\"class\\\": \\\"foam.tmp.TransformedCountry\\\",\\u000a\\u0009\\u0009\\\"double\\\": 37.6,\\u000a\\u0009\\u0009\\\"code\\\": \\\"AG\\\",\\u000a\\u0009\\u0009\\\"isoNumeric\\\": \\\"028\\\",\\u000a\\u0009\\u0009\\\"iso31661Code\\\": \\\"ATG\\\",\\u000a\\u0009\\u0009\\\"name\\\": \\\"Antigua and Barbuda\\\",\\u000a\\u0009\\u0009\\\"longName\\\": \\\"Antigua and Barbuda\\\",\\u000a\\u0009\\u0009\\\"nativeName\\\": \\\"Antigua and Barbuda\\\",\\u000a\\u0009\\u0009\\\"alternativeNames\\\": [\\u000a\\u0009\\u0009\\u0009\\u000a\\u0009\\u0009],\\u000a\\u0009\\u0009\\\"geographicRegion\\\": \\\"Latin America & Caribbean\\\",\\u000a\\u0009\\u0009\\\"phoneCode\\\": \\\"1\\\",\\u000a\\u0009\\u0009\\\"emoji\\\": \\\"\ud83c\udde6\ud83c\uddec\\\"\\u000a\\u0009},\\u000a\\u0009{\\u000a\\u0009\\u0009\\\"class\\\": \\\"foam.tmp.TransformedCountry\\\",\\u000a\\u0009\\u0009\\\"double\\\": 37.8,\\u000a\\u0009\\u0009\\\"code\\\": \\\"AI\\\",\\u000a\\u0009\\u0009\\\"isoNumeric\\\": \\\"660\\\",\\u000a\\u0009\\u0009\\\"iso31661Code\\\": \\\"AIA\\\",\\u000a\\u0009\\u0009\\\"name\\\": \\\"Anguilla\\\",\\u000a\\u0009\\u0009\\\"nativeName\\\": \\\"Anguilla\\\",\\u000a\\u0009\\u0009\\\"alternativeNames\\\": [\\u000a\\u0009\\u0009\\u0009\\u000a\\u0009\\u0009],\\u000a\\u0009\\u0009\\\"phoneCode\\\": \\\"1\\\",\\u000a\\u0009\\u0009\\\"emoji\\\": \\\"\ud83c\udde6\ud83c\uddee\\\"\\u000a\\u0009}\\u000a]\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"a1\",\n\t\t\"cmd\": \"console.log(test3data.value)\"\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test4data\",\n\t\t\"cmd\": \"dao(testdata.limitedDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test 4 Data\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.AvgDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.tmp.TransformedCountry\",\n\t\t\t\t\t\"name\": \"double\"\n\t\t\t\t}\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 1\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test4\",\n\t\t\"cmd\": \"test(test4data.value.value, 'Verify Avg Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Avg Operation for Table Column\",\n\t\t\t\"expected\": \"37.92\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test5data\",\n\t\t\"cmd\": \"dao regions\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test 5 Data\",\n\t\t\t\"limit\": 0,\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.CountDAOAgent\"\n\t\t\t},\n\t\t\t\"rowCount\": 1061,\n\t\t\t\"version\": 2\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test5\",\n\t\t\"cmd\": \"test(test5data.value.value, 'Verify Count Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Count Operation for Table Column\",\n\t\t\t\"expected\": \"1061\"\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test6data\",\n\t\t\"cmd\": \"dao(testdata.limitedDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Test 6 Data\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.MaxDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.tmp.TransformedCountry\",\n\t\t\t\t\t\"name\": \"double\"\n\t\t\t\t}\n\t\t\t},\n\t\t\t\"rowCount\": 245,\n\t\t\t\"version\": 1\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test6\",\n\t\t\"cmd\": \"test(test6data.value.value, 'Verify Max Operation for Table Column')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Verify Max Operation for Table Column\",\n\t\t\t\"expected\": \"38.6\"\n\t\t}\n\t}\n]",lastModified:1751464069515})

// Test for nested GroupBys
p({class:"foam.core.reflow.Flow",name:"FLOAT: GroupByGroupBytoDAO",status:"PASSED (Passed=1, Failed=0)",version:8,script:"[\n\t{\n\t\t\n\t\t\"flowName\": \"testResults\",\n\t\t\"cmd\": \"testresults\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.TestResults\",\n\t\t\t\"total\": 1\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"regions1\",\n\t\t\"cmd\": \"dao region\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Regions\",\n\t\t\t\"columns\": \"name,countryId,isoCode\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.GroupByDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.core.auth.Region\",\n\t\t\t\t\t\"name\": \"countryId\"\n\t\t\t\t},\n\t\t\t\t\"sink\": {\n\t\t\t\t\t\"class\": \"foam.core.reflow.GroupByDAOAgent\",\n\t\t\t\t\t\"prop\": {\n\t\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\t\"forClass_\": \"foam.core.auth.Region\",\n\t\t\t\t\t\t\"name\": \"name\"\n\t\t\t\t\t},\n\t\t\t\t\t\"sink\": {\n\t\t\t\t\t\t\"class\": \"foam.core.reflow.CountDAOAgent\"\n\t\t\t\t\t},\n\t\t\t\t\t\"browseEnabled\": false\n\t\t\t\t},\n\t\t\t\t\"browseEnabled\": true\n\t\t\t},\n\t\t\t\"rowCount\": 1061,\n\t\t\t\"version\": 8\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"regions1groupby1\",\n\t\t\"cmd\": \"dao(regions1.value.asDAO(), 'regions1GroupBy')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"regions1GroupBy\",\n\t\t\t\"columns\": \"countryId,name,count\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.CSVDAOAgent\"\n\t\t\t},\n\t\t\t\"rowCount\": 99,\n\t\t\t\"version\": 7\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test1\",\n\t\t\"cmd\": \"test(regions1groupby1.value, 'Test GropuByGroupBy asDAO()')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Test GropuByGroupBy asDAO()\",\n\t\t\t\"expected\": \"id,row,countryId,name,count\\u000a1,1,BE,Antwerp,1\\u000a2,2,BR,Acre,1\\u000a3,3,BR,Alagoas,1\\u000a4,4,BR,Amap\u00e1,1\\u000a5,5,BR,Amazonas,1\\u000a6,6,BR,Bahia,1\\u000a7,7,CA,Alberta,1\\u000a8,8,CN,Anhui Province,1\\u000a9,9,CN,Beijing Municipality,1\\u000a10,10,DE,Baden-W\u00fcrttemberg,1\\u000a11,11,DE,Bayern,1\\u000a12,12,DE,Berlin,1\\u000a13,13,DE,Brandenburg,1\\u000a14,14,ES,Albacete,1\\u000a15,15,ES,Alicante,1\\u000a16,16,ES,Almer\u00eda,1\\u000a17,17,ES,Andalucia,1\\u000a18,18,ES,Aragon,1\\u000a19,19,ES,Asturias,2\\u000a20,20,ES,Badajoz,1\\u000a21,21,ES,Baleares,1\\u000a22,22,ES,Balearic Islands,1\\u000a23,23,ES,Barcelona,1\\u000a24,24,ES,Basque Country,1\\u000a25,25,FR,Ain,1\\u000a26,26,FR,Aisne,1\\u000a27,27,FR,Allier,1\\u000a28,28,FR,Alpes-de-Haute-Provence,1\\u000a29,29,FR,Alpes-Maritimes,1\\u000a30,30,FR,Alsace,1\\u000a31,31,FR,Aquitaine,1\\u000a32,32,FR,Ard\u00e8che,1\\u000a33,33,FR,Ardennes,1\\u000a34,34,FR,Ari\u00e8ge,1\\u000a35,35,FR,Aube,1\\u000a36,36,FR,Aude,1\\u000a37,37,FR,Auvergne,1\\u000a38,38,FR,Aveyron,1\\u000a39,39,FR,Bas-Rhin,1\\u000a40,40,FR,Basse-Normandie,1\\u000a41,41,FR,Bauches-du-Rh\u00f4ne,1\\u000a42,42,FR,Bourgogne,1\\u000a43,43,GR,Acha\u00efa,1\\u000a44,44,GR,Agio Oros,1\\u000a45,45,GR,Aitolia-Akarnania,1\\u000a46,46,GR,Argolis,1\\u000a47,47,GR,Arkadia,1\\u000a48,48,GR,Arta,1\\u000a49,49,GR,Attica,1\\u000a50,50,GR,Attiki,1\\u000a51,51,IN,Andaman and Nicobar Islands,1\\u000a52,52,IN,Andhra Pradesh,1\\u000a53,53,IN,Arunachal Pradesh,1\\u000a54,54,IN,Assam,1\\u000a55,55,IN,Bihar,1\\u000a56,56,IT,Abruzzo,1\\u000a57,57,IT,Aosta Valley,1\\u000a58,58,IT,Apulia,1\\u000a59,59,IT,Basilicata,1\\u000a60,60,LB,Akk\u0101r,1\\u000a61,61,LB,Baalbek-Hermel,1\\u000a62,62,LB,Bayr\u016bt,1\\u000a63,63,LT,Alytus County,1\\u000a64,64,MT,Attard,1\\u000a65,65,MT,Balzan,1\\u000a66,66,MT,Birgu,1\\u000a67,67,MT,Birkirkara,1\\u000a68,68,MT,Birzebbuga,1\\u000a69,69,MT,Bormla,1\\u000a70,70,MX,Aguascalientes,1\\u000a71,71,MX,Baja California,1\\u000a72,72,MX,Baja California Sur,1\\u000a73,73,PK,Azad Jammu and Kashmir,1\\u000a74,74,PK,Balochistan,1\\u000a75,75,PT,Aveiro,1\\u000a76,76,PT,Azores,1\\u000a77,77,PT,Beja,1\\u000a78,78,PT,Braga,1\\u000a79,79,PT,Bragan\u00e7a,1\\u000a80,80,RS,Borski okrug,1\\u000a81,81,RS,Brani\u010devski okrug,1\\u000a82,82,SE,Blekinge,1\\u000a83,83,SI,Ajdov\u0161cina,1\\u000a84,84,SI,Ankaran,1\\u000a85,85,SI,Apa\u010de,1\\u000a86,86,SI,Beltinci,1\\u000a87,87,SI,Benedikt,1\\u000a88,88,SI,Bistrica ob Sotli,1\\u000a89,89,SI,Bled,1\\u000a90,90,SI,Bloke,1\\u000a91,91,SI,Bohinj,1\\u000a92,92,SI,Borovnica,1\\u000a93,93,SI,Bovec,1\\u000a94,94,SK,Banskobystrick\u00fd kraj,1\\u000a95,95,UA,Avtonomna Respublika Krym,1\\u000a96,96,US,Alabama,1\\u000a97,97,US,Alaska,1\\u000a98,98,US,Arizona,1\\u000a99,99,US,Arkansas,1\\u000a\"\n\t\t}\n\t}\n]"})

// Security Audit
p({class:"foam.core.reflow.Flow",name:"Security Audit",version:2,script:"[\n\t{\n\t\t\n\t\t\"flowName\": \"script1\",\n\t\t\"cmd\": \"script\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.Script\",\n\t\t\t\"code\": \"foam.ENUM({\\u000a  package: 'foam.security',\\u000a  name: 'Status',\\u000a  values: [\\u000a    { name: 'PASSED',                        color: 'green' },\\u000a    { name: 'PASSED_STAR', label: 'PASSED*', color: 'lightgreen' },\\u000a    { name: 'ALERT',                         color: 'red' },\\u000a    { name: 'WARNING',                       color: 'orange' }\\u000a  ]\\u000a});\\u000a\\u000afoam.CLASS({\\u000a  package: 'foam.security',\\u000a  name: 'SecurityAudit',\\u000a  properties: [\\u000a    { name: 'id', label: 'DAO' },\\u000a    { class: 'Enum',    name: 'status', of: 'foam.security.Status' },\\u000a    { class: 'Boolean', name: 'authenticated' },\\u000a    { class: 'Boolean', name: 'permissioned' },\\u000a    { class: 'Boolean', name: 'readOnly' },\\u000a    { class: 'Boolean', name: 'spidAware', label: 'SPID Aware' },\\u000a    { class: 'String',  name: 'authorizer' },\\u000a    { class: 'String',  name: 'groups' },\\u000a    { class: 'String',  name: 'capabilities' },\\u000a    { class: 'String',  name: 'notes' }\\u000a  ]\\u000a});\\u000a\\u000avar dao = foam.dao.EasyDAO.create({\\u000a  of:      foam.security.SecurityAudit,\\u000a  daoType: 'MDAO'\\u000a});\\u000a\\u000avar IGNORED_GROUPS = {\\u000a  admin:  true,\\u000a  system: true\\u000a};\\u000a\\u000avar data   = [];\\u000avar groups = await x.groupDAO.select();      groups = groups.array;\\u000avar caps   = await x.capabilityDAO.select(); caps   = caps.array;\\u000a\\u000a\\u000avar array = await x.cSpecDAO.select();\\u000aarray = array.array;\\u000afor ( var i = 0 ; i < array.length ; i++ ) {\\u000a  var n = array[i];\\u000a  if ( n.name.indexOf('DAO') == -1 ) continue;\\u000a  if ( ! n.serve )  continue;\\u000a  if ( ! n.enabled )  continue;\\u000a\\u000a  let authorizer   = '';\\u000a  let permissioned = false;\\u000a  let readOnly     = false;\\u000a  let nullDAO      = false;\\u000a  let spidAware    = false;\\u000a\\u000a  try {\\u000a    readOnly   = !! await x[n.name].cmd('CLASS? foam.dao.ReadOnlyDAO');\\u000a  } catch (x) { }\\u000a\\u000a  try {\\u000a    nullDAO   = !! await x[n.name].cmd('CLASS? foam.dao.NullDAO');\\u000a  } catch (x) { }\\u000a\\u000a  try { authorizer = await x[n.name].cmd('AUTHORIZER?'); } catch (x) { }\\u000a  try { permissioned = !! await x[n.name].cmd('CLASS? foam.core.auth.PermissionedPropertyDAO'); } catch (x) { }\\u000a  try { spidAware = !! await x[n.name].cmd('CLASS? foam.core.auth.ServiceProviderAwareDAO'); } catch (x) { }\\u000a\\u000a  if ( authorizer ) {\\u000a    authorizer = authorizer.replace('foam.core.auth.', '');\\u000a    authorizer = authorizer.replace('foam.core.approval.', '');\\u000a    authorizer = authorizer.replace('Authorizer', '');\\u000a  }\\u000a\\u000a  var pgroups = [];\\u000a  for ( var j = 0 ; j < groups.length ; j++ ) {\\u000a    var g = groups[j];\\u000a    if ( ! IGNORED_GROUPS[g.id] && await g.implies(x, 'service.' + n.name) ) {\\u000a      pgroups.push(g.id);\\u000a    }\\u000a  }\\u000a\\u000a  var pcaps = [];\\u000a  for ( var j = 0 ; j < caps.length ; j++ ) {\\u000a    var c = caps[j];\\u000a    var granted =  c.permissionsGranted.find(p => {\\u000a      return p === 'service.' + n.name;\\u000a    });\\u000a    if ( granted ) {\\u000a      pcaps.push(c.name);\\u000a    }\\u000a  }\\u000a\\u000a  let warning = foam.security.Status.PASSED;\\u000a  if  ( ! authorizer && ! readOnly && ! n.authenticate && ! nullDAO ) {\\u000a    warning = foam.security.Status.ALERT;\\u000a  } else if ( ! authorizer && pgroups.length && ! readOnly && ! nullDAO ) {\\u000a    warning = foam.security.Status.WARNING;\\u000a  }\\u000a  if ( warning == foam.security.Status.WARNING && n.authNotes ) warning = foam.security.Status.PASSED_STAR;\\u000a\\u000a  dao.put(foam.security.SecurityAudit.create({\\u000a    id: n.name,\\u000a    status: warning,\\u000a    authenticated: n.authenticate,\\u000a    authorizer: authorizer || '',\\u000a    permissioned: permissioned,\\u000a    readOnly: readOnly,\\u000a    spidAware: spidAware,\\u000a    groups: pgroups.join(', '),\\u000a    capabilities: pcaps.join(', '),\\u000a    notes: n.authNotes\\u000a  }));\\u000a}\\u000a\\u000aglobalThis.auditDAO = dao;\\u000a\",\n\t\t\t\"autoRun\": true\n\t\t},\n\t\t\"borderClass\": \"foam.u2.borders.NullBorder\",\n\t\t\"border\": {\n\t\t\t\"cssClasses\": [\n\t\t\t\t\n\t\t\t]\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"securityaudits1\",\n\t\t\"cmd\": \"dao(globalThis.auditDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Security Audits\",\n\t\t\t\"columns\": \"id,status,authenticated,permissioned,readOnly,spidAware,authorizer,groups,capabilities,notes\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.TableDAOAgent\",\n\t\t\t\t\"columns\": [\n\t\t\t\t\t\n\t\t\t\t]\n\t\t\t},\n\t\t\t\"rowCount\": 204,\n\t\t\t\"version\": 1\n\t\t},\n\t\t\"borderClass\": \"foam.u2.borders.NullBorder\",\n\t\t\"border\": {\n\t\t\t\"cssClasses\": [\n\t\t\t\t\n\t\t\t]\n\t\t}\n\t}\n]",lastModified:1754917971884})
