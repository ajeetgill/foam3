p({class:"foam.core.reflow.Flow",name:"FLOAT: GroupByGroupBytoDAO",status:"PASSED (Passed=1, Failed=0)",version:8,script:"[\n\t{\n\t\t\n\t\t\"flowName\": \"testResults\",\n\t\t\"cmd\": \"testresults\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.TestResults\",\n\t\t\t\"total\": 1\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"regions1\",\n\t\t\"cmd\": \"dao region\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Regions\",\n\t\t\t\"columns\": \"name,countryId,isoCode\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.GroupByDAOAgent\",\n\t\t\t\t\"prop\": {\n\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\"forClass_\": \"foam.core.auth.Region\",\n\t\t\t\t\t\"name\": \"countryId\"\n\t\t\t\t},\n\t\t\t\t\"sink\": {\n\t\t\t\t\t\"class\": \"foam.core.reflow.GroupByDAOAgent\",\n\t\t\t\t\t\"prop\": {\n\t\t\t\t\t\t\"class\": \"__Property__\",\n\t\t\t\t\t\t\"forClass_\": \"foam.core.auth.Region\",\n\t\t\t\t\t\t\"name\": \"name\"\n\t\t\t\t\t},\n\t\t\t\t\t\"sink\": {\n\t\t\t\t\t\t\"class\": \"foam.core.reflow.CountDAOAgent\"\n\t\t\t\t\t},\n\t\t\t\t\t\"browseEnabled\": false\n\t\t\t\t},\n\t\t\t\t\"browseEnabled\": true\n\t\t\t},\n\t\t\t\"rowCount\": 1061,\n\t\t\t\"version\": 8\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"regions1groupby1\",\n\t\t\"cmd\": \"dao(regions1.value.asDAO(), 'regions1GroupBy')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"regions1GroupBy\",\n\t\t\t\"columns\": \"countryId,name,count\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.CSVDAOAgent\"\n\t\t\t},\n\t\t\t\"rowCount\": 99,\n\t\t\t\"version\": 7\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"test1\",\n\t\t\"cmd\": \"test(regions1groupby1.value, 'Test GropuByGroupBy asDAO()')\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.float.Test\",\n\t\t\t\"description\": \"Test GropuByGroupBy asDAO()\",\n\t\t\t\"expected\": \"id,row,countryId,name,count\\u000a1,1,BE,Antwerp,1\\u000a2,2,BR,Acre,1\\u000a3,3,BR,Alagoas,1\\u000a4,4,BR,Amap\u00e1,1\\u000a5,5,BR,Amazonas,1\\u000a6,6,BR,Bahia,1\\u000a7,7,CA,Alberta,1\\u000a8,8,CN,Anhui Province,1\\u000a9,9,CN,Beijing Municipality,1\\u000a10,10,DE,Baden-W\u00fcrttemberg,1\\u000a11,11,DE,Bayern,1\\u000a12,12,DE,Berlin,1\\u000a13,13,DE,Brandenburg,1\\u000a14,14,ES,Albacete,1\\u000a15,15,ES,Alicante,1\\u000a16,16,ES,Almer\u00eda,1\\u000a17,17,ES,Andalucia,1\\u000a18,18,ES,Aragon,1\\u000a19,19,ES,Asturias,2\\u000a20,20,ES,Badajoz,1\\u000a21,21,ES,Baleares,1\\u000a22,22,ES,Balearic Islands,1\\u000a23,23,ES,Barcelona,1\\u000a24,24,ES,Basque Country,1\\u000a25,25,FR,Ain,1\\u000a26,26,FR,Aisne,1\\u000a27,27,FR,Allier,1\\u000a28,28,FR,Alpes-de-Haute-Provence,1\\u000a29,29,FR,Alpes-Maritimes,1\\u000a30,30,FR,Alsace,1\\u000a31,31,FR,Aquitaine,1\\u000a32,32,FR,Ard\u00e8che,1\\u000a33,33,FR,Ardennes,1\\u000a34,34,FR,Ari\u00e8ge,1\\u000a35,35,FR,Aube,1\\u000a36,36,FR,Aude,1\\u000a37,37,FR,Auvergne,1\\u000a38,38,FR,Aveyron,1\\u000a39,39,FR,Bas-Rhin,1\\u000a40,40,FR,Basse-Normandie,1\\u000a41,41,FR,Bauches-du-Rh\u00f4ne,1\\u000a42,42,FR,Bourgogne,1\\u000a43,43,GR,Acha\u00efa,1\\u000a44,44,GR,Agio Oros,1\\u000a45,45,GR,Aitolia-Akarnania,1\\u000a46,46,GR,Argolis,1\\u000a47,47,GR,Arkadia,1\\u000a48,48,GR,Arta,1\\u000a49,49,GR,Attica,1\\u000a50,50,GR,Attiki,1\\u000a51,51,IN,Andaman and Nicobar Islands,1\\u000a52,52,IN,Andhra Pradesh,1\\u000a53,53,IN,Arunachal Pradesh,1\\u000a54,54,IN,Assam,1\\u000a55,55,IN,Bihar,1\\u000a56,56,IT,Abruzzo,1\\u000a57,57,IT,Aosta Valley,1\\u000a58,58,IT,Apulia,1\\u000a59,59,IT,Basilicata,1\\u000a60,60,LB,Akk\u0101r,1\\u000a61,61,LB,Baalbek-Hermel,1\\u000a62,62,LB,Bayr\u016bt,1\\u000a63,63,LT,Alytus County,1\\u000a64,64,MT,Attard,1\\u000a65,65,MT,Balzan,1\\u000a66,66,MT,Birgu,1\\u000a67,67,MT,Birkirkara,1\\u000a68,68,MT,Birzebbuga,1\\u000a69,69,MT,Bormla,1\\u000a70,70,MX,Aguascalientes,1\\u000a71,71,MX,Baja California,1\\u000a72,72,MX,Baja California Sur,1\\u000a73,73,PK,Azad Jammu and Kashmir,1\\u000a74,74,PK,Balochistan,1\\u000a75,75,PT,Aveiro,1\\u000a76,76,PT,Azores,1\\u000a77,77,PT,Beja,1\\u000a78,78,PT,Braga,1\\u000a79,79,PT,Bragan\u00e7a,1\\u000a80,80,RS,Borski okrug,1\\u000a81,81,RS,Brani\u010devski okrug,1\\u000a82,82,SE,Blekinge,1\\u000a83,83,SI,Ajdov\u0161cina,1\\u000a84,84,SI,Ankaran,1\\u000a85,85,SI,Apa\u010de,1\\u000a86,86,SI,Beltinci,1\\u000a87,87,SI,Benedikt,1\\u000a88,88,SI,Bistrica ob Sotli,1\\u000a89,89,SI,Bled,1\\u000a90,90,SI,Bloke,1\\u000a91,91,SI,Bohinj,1\\u000a92,92,SI,Borovnica,1\\u000a93,93,SI,Bovec,1\\u000a94,94,SK,Banskobystrick\u00fd kraj,1\\u000a95,95,UA,Avtonomna Respublika Krym,1\\u000a96,96,US,Alabama,1\\u000a97,97,US,Alaska,1\\u000a98,98,US,Arizona,1\\u000a99,99,US,Arkansas,1\\u000a\"\n\t\t}\n\t}\n]"})

// Security Audit
p({class:"foam.core.reflow.Flow",name:"Security Audit",script:"[\n\t{\n\t\t\n\t\t\"flowName\": \"script1\",\n\t\t\"cmd\": \"script\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.Script\",\n\t\t\t\"code\": \"foam.ENUM({\\n  package: 'foam.security',\\n  name: 'Status',\\n  values: [\\n    { name: 'PASSED',                        color: 'green' },\\n    { name: 'PASSED_STAR', label: 'PASSED*', color: 'lightgreen' },\\n    { name: 'ALERT',                         color: 'red' },\\n    { name: 'WARNING',                       color: 'orange' }\\n  ]\\n});\\n\\nfoam.CLASS({\\n  package: 'foam.security',\\n  name: 'SecurityAudit',\\n  properties: [\\n    { name: 'id', label: 'DAO' },\\n    { class: 'Enum',    name: 'status', of: 'foam.security.Status' },\\n    { class: 'Boolean', name: 'authenticated' },\\n    { class: 'Boolean', name: 'permissioned' },\\n    { class: 'Boolean', name: 'readOnly' },\\n    { class: 'Boolean', name: 'spidAware', label: 'SPID Aware' },\\n    { class: 'Boolean', name: 'programAware' },\\n    { class: 'String',  name: 'authorizer' },\\n    { class: 'String',  name: 'groups' },\\n    { class: 'String',  name: 'capabilities' },\\n    { class: 'String',  name: 'notes' }\\n  ]\\n});\\n\\nvar dao = foam.dao.EasyDAO.create({\\n  of:      foam.security.SecurityAudit,\\n  daoType: 'MDAO'\\n});\\n\\nvar IGNORED_GROUPS = {\\n  admin:  true,\\n  system: true\\n};\\n\\nvar data   = [];\\nvar groups = await x.groupDAO.select();      groups = groups.array;\\nvar caps   = await x.capabilityDAO.select(); caps   = caps.array;\\n\\n\\nvar array = await x.cSpecDAO.select();\\narray = array.array;\\nfor ( var i = 0 ; i < array.length ; i++ ) {\\n  var n = array[i];\\n  if ( n.name.indexOf('DAO') == -1 ) continue;\\n  if ( ! n.serve )  continue;\\n  if ( ! n.enabled )  continue;\\n\\n  let authorizer   = '';\\n  let permissioned = false;\\n  let readOnly     = false;\\n  let nullDAO      = false;\\n  let spidAware    = false;\\n  let programAware = false;\\n\\n  try {\\n    readOnly   = !! await x[n.name].cmd('CLASS? foam.dao.ReadOnlyDAO');\\n  } catch (x) { }\\n\\n  try {\\n    nullDAO   = !! await x[n.name].cmd('CLASS? foam.dao.NullDAO');\\n  } catch (x) { }\\n\\n  try { authorizer = await x[n.name].cmd('AUTHORIZER?'); } catch (x) { }\\n  try { permissioned = !! await x[n.name].cmd('CLASS? foam.core.auth.PermissionedPropertyDAO'); } catch (x) { }\\n  try { spidAware = !! await x[n.name].cmd('CLASS? foam.core.auth.ServiceProviderAwareDAO'); } catch (x) { }\\n  try { programAware = !! await x[n.name].cmd('CLASS? com.paytic.identity.ProgramAwareDAO'); } catch (x) { }\\n\\n  if ( authorizer ) {\\n    authorizer = authorizer.replace('foam.core.auth.', '');\\n    authorizer = authorizer.replace('foam.core.approval.', '');\\n    authorizer = authorizer.replace('Authorizer', '');\\n  }\\n\\n  var pgroups = [];\\n  for ( var j = 0 ; j < groups.length ; j++ ) {\\n    var g = groups[j];\\n    if ( ! IGNORED_GROUPS[g.id] && await g.implies(x, 'service.' + n.name) ) {\\n      pgroups.push(g.id);\\n    }\\n  }\\n\\n  var pcaps = [];\\n  for ( var j = 0 ; j < caps.length ; j++ ) {\\n    var c = caps[j];\\n    var granted =  c.permissionsGranted.find(p => {\\n      return p === 'service.' + n.name;\\n    });\\n    if ( granted ) {\\n      pcaps.push(c.name);\\n    }\\n  }\\n\\n  let warning = foam.security.Status.PASSED;\\n  if  ( ! authorizer && ! readOnly && ! n.authenticate && ! nullDAO ) {\\n    warning = foam.security.Status.ALERT;\\n  } else if ( ! authorizer && pgroups.length && ! readOnly && ! nullDAO ) {\\n    warning = foam.security.Status.WARNING;\\n  }\\n  if ( warning == foam.security.Status.WARNING && n.authNotes ) warning = foam.security.Status.PASSED_STAR;\\n\\n  dao.put(foam.security.SecurityAudit.create({\\n    id: n.name,\\n    status: warning,\\n    authenticated: n.authenticate,\\n    authorizer: authorizer || '',\\n    permissioned: permissioned,\\n    readOnly: readOnly,\\n    spidAware: spidAware,\\n    programAware: programAware,\\n    groups: pgroups.join(', '),\\n    capabilities: pcaps.join(', '),\\n    notes: n.authNotes\\n  }));\\n}\\n\\nglobalThis.auditDAO = dao;\\n\",\n\t\t\t\"autoRun\": true\n\t\t},\n\t\t\"borderClass\": \"foam.u2.borders.NullBorder\",\n\t\t\"border\": {\n\t\t\t\"cssClasses\": [\n\t\t\t\t\n\t\t\t]\n\t\t}\n\t},\n\t{\n\t\t\n\t\t\"flowName\": \"securityaudits1\",\n\t\t\"cmd\": \"dao(globalThis.auditDAO)\",\n\t\t\"value\": {\n\t\t\t\"class\": \"foam.core.reflow.DAOPrompt\",\n\t\t\t\"label\": \"Security Audits\",\n\t\t\t\"columns\": \"id,status,authenticated,permissioned,readOnly,spidAware,authorizer,groups,capabilities,notes\",\n\t\t\t\"select\": {\n\t\t\t\t\"class\": \"foam.core.reflow.TableDAOAgent\",\n\t\t\t\t\"columns\": [\n\t\t\t\t\t\n\t\t\t\t]\n\t\t\t},\n\t\t\t\"rowCount\": 204,\n\t\t\t\"version\": 1\n\t\t},\n\t\t\"borderClass\": \"foam.u2.borders.NullBorder\",\n\t\t\"border\": {\n\t\t\t\"cssClasses\": [\n\t\t\t\t\n\t\t\t]\n\t\t}\n\t}\n]",lastModified:1755031194724})

