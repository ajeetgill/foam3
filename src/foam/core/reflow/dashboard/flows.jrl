p({
"class":"foam.core.reflow.Flow",
"name":"PieLegendTest",
"version":1,
"script":"[{\"flowName\":\"title\",\"cmd\":\"h Pie Legend Test\",\"value\":{\"class\":\"foam.core.reflow.Header\",\"type\":\"h2\",\"text\":\"Pie Legend Test\"},\"padding_st\":\"16px\"},{\"flowName\":\"intro\",\"cmd\":\"markdown\",\"value\":{\"class\":\"foam.core.reflow.Markdown\",\"markdown\":\"Data source: `logMessageDAO` grouped by `severity`. Each row below isolates one aspect of DashboardPieSink legend behavior.\"},\"padding_st\":\"16px\"},{\"flowName\":\"group1_header\",\"cmd\":\"h Cases 1-4: showPercentages × disableLegendClick\",\"value\":{\"class\":\"foam.core.reflow.Header\",\"type\":\"h3\",\"text\":\"Cases 1-4: showPercentages × disableLegendClick\"},\"padding_st\":\"16px\"},{\"flowName\":\"group1\",\"cmd\":\"layout\",\"value\":{\"class\":\"foam.u2.layout.Layout\",\"layoutType\":\"row\"},\"flowChildren\":[{\"flowName\":\"case1\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"showPercentages\":false,\"disableLegendClick\":false,\"legendPosition\":\"RIGHT\"}},\"border\":{\"title\":\"Case 1 (pct:false, click:false) — baseline toggle\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"case2\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"showPercentages\":false,\"disableLegendClick\":true,\"legendPosition\":\"RIGHT\"}},\"border\":{\"title\":\"Case 2 (pct:false, click:true) — no-op disables toggle\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"case3\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"showPercentages\":true,\"disableLegendClick\":false,\"legendPosition\":\"RIGHT\"}},\"border\":{\"title\":\"Case 3 (pct:true, click:false) — toggle works w/ percentages\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"case4\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"showPercentages\":true,\"disableLegendClick\":true,\"legendPosition\":\"RIGHT\"}},\"border\":{\"title\":\"Case 4 (pct:true, click:true) — no-op still works w/ generateLabels\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"}]},{\"flowName\":\"group2_header\",\"cmd\":\"h Case 5: legendPosition variants (short labels — no drift)\",\"value\":{\"class\":\"foam.core.reflow.Header\",\"type\":\"h3\",\"text\":\"Case 5: legendPosition variants (short labels — no drift)\"},\"padding_st\":\"16px\"},{\"flowName\":\"group2\",\"cmd\":\"layout\",\"value\":{\"class\":\"foam.u2.layout.Layout\",\"layoutType\":\"row\"},\"flowChildren\":[{\"flowName\":\"case5a\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"TOP\"}},\"border\":{\"title\":\"TOP\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"case5b\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"BOTTOM\"}},\"border\":{\"title\":\"BOTTOM\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"case5c\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"LEFT\"}},\"border\":{\"title\":\"LEFT\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"case5d\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"RIGHT\"}},\"border\":{\"title\":\"RIGHT\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"}]},{\"flowName\":\"drift_header\",\"cmd\":\"h Vertical alignment — legendMinWidthPercent\",\"value\":{\"class\":\"foam.core.reflow.Header\",\"type\":\"h3\",\"text\":\"Vertical alignment — legendMinWidthPercent\"},\"padding_st\":\"16px\"},{\"flowName\":\"drift_explanation\",\"cmd\":\"markdown\",\"value\":{\"class\":\"foam.core.reflow.Markdown\",\"markdown\":\"Three columns, each stacking three pies with different `othersLabel` lengths (short / medium / long). Watch where the arc centers sit within each column.\\n\\n- **Before** — no min, no cap → short legends let the arc grow; long legends squeeze it. Arc x-centers drift between rows.\\n- **legendMinWidthPercent:40** — reserves 40% of container width on the legend side. Short legends pad out; long legends still overflow naturally. Arc centers inside this column should line up vertically.\\n- **legendMaxWidthPercent:40** — caps the legend at 40% of container width (long labels wrap/truncate). Short legends still float free. Useful when labels can get unboundedly long; not an alignment tool on its own.\\n\\nCombining both usually backfires: `layout.padding` (min) stacks on top of the Chart.js legend area (max), squeezing the arc.\"},\"padding_st\":\"16px\"},{\"flowName\":\"drift_demo\",\"cmd\":\"layout\",\"value\":{\"class\":\"foam.u2.layout.Layout\",\"layoutType\":\"row\"},\"flowChildren\":[{\"flowName\":\"drift_before\",\"cmd\":\"layout\",\"value\":{\"class\":\"foam.u2.layout.Layout\",\"layoutType\":\"column\"},\"flowChildren\":[{\"flowName\":\"drift_before_label\",\"cmd\":\"markdown\",\"value\":{\"class\":\"foam.core.reflow.Markdown\",\"markdown\":\"**Before (no min/max)**\"},\"padding_st\":\"16px\"},{\"flowName\":\"drift_before_short\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"RIGHT\",\"topN\":1,\"includeOthers\":true,\"othersLabel\":\"X\"}},\"border\":{\"title\":\"short othersLabel\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"drift_before_medium\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"RIGHT\",\"topN\":1,\"includeOthers\":true,\"othersLabel\":\"Other log levels\"}},\"border\":{\"title\":\"medium othersLabel\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"drift_before_long\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"RIGHT\",\"topN\":1,\"includeOthers\":true,\"othersLabel\":\"Combined remaining severities (aggregate)\"}},\"border\":{\"title\":\"long othersLabel\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"}]},{\"flowName\":\"drift_minonly\",\"cmd\":\"layout\",\"value\":{\"class\":\"foam.u2.layout.Layout\",\"layoutType\":\"column\"},\"flowChildren\":[{\"flowName\":\"drift_minonly_label\",\"cmd\":\"markdown\",\"value\":{\"class\":\"foam.core.reflow.Markdown\",\"markdown\":\"**legendMinWidthPercent:40**\"},\"padding_st\":\"16px\"},{\"flowName\":\"drift_minonly_short\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"RIGHT\",\"topN\":1,\"includeOthers\":true,\"othersLabel\":\"X\",\"legendMinWidthPercent\":40}},\"border\":{\"title\":\"short othersLabel\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"drift_minonly_medium\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"RIGHT\",\"topN\":1,\"includeOthers\":true,\"othersLabel\":\"Other log levels\",\"legendMinWidthPercent\":40}},\"border\":{\"title\":\"medium othersLabel\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"drift_minonly_long\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"RIGHT\",\"topN\":1,\"includeOthers\":true,\"othersLabel\":\"Combined remaining severities (aggregate)\",\"legendMinWidthPercent\":40}},\"border\":{\"title\":\"long othersLabel\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"}]},{\"flowName\":\"drift_maxonly\",\"cmd\":\"layout\",\"value\":{\"class\":\"foam.u2.layout.Layout\",\"layoutType\":\"column\"},\"flowChildren\":[{\"flowName\":\"drift_maxonly_label\",\"cmd\":\"markdown\",\"value\":{\"class\":\"foam.core.reflow.Markdown\",\"markdown\":\"**legendMaxWidthPercent:40**\"},\"padding_st\":\"16px\"},{\"flowName\":\"drift_maxonly_short\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"RIGHT\",\"topN\":1,\"includeOthers\":true,\"othersLabel\":\"X\",\"legendMaxWidthPercent\":40}},\"border\":{\"title\":\"short othersLabel\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"drift_maxonly_medium\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"RIGHT\",\"topN\":1,\"includeOthers\":true,\"othersLabel\":\"Other log levels\",\"legendMaxWidthPercent\":40}},\"border\":{\"title\":\"medium othersLabel\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"},{\"flowName\":\"drift_maxonly_long\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"class\":\"foam.core.reflow.DAOPrompt\",\"limit\":0,\"select\":{\"class\":\"foam.core.reflow.dashboard.DashboardPieChartDAOAgent\",\"prop\":{\"class\":\"__Property__\",\"forClass_\":\"foam.core.logger.LogMessage\",\"name\":\"severity\"},\"sink\":{\"class\":\"foam.core.reflow.CountDAOAgent\"},\"cutoutPercentage\":60,\"legendPosition\":\"RIGHT\",\"topN\":1,\"includeOthers\":true,\"othersLabel\":\"Combined remaining severities (aggregate)\",\"legendMaxWidthPercent\":40}},\"border\":{\"title\":\"long othersLabel\",\"oldTitleStyle_\":\"h300\"},\"padding_st\":\"8px\"}]}]},{\"flowName\":\"group4_header\",\"cmd\":\"h chartAlignment — shift arc within remaining area\",\"value\":{\"class\":\"foam.core.reflow.Header\",\"type\":\"h3\",\"text\":\"chartAlignment — shift arc within remaining area\"},\"padding_st\":\"16px\"},{\"flowName\":\"group4\",\"cmd\":\"layout\",\"value\":{\"class\":\"foam.u2.layout.Layout\",\"layoutType\":\"row\"},\"flowChildren\":[{\"flowName\":\"case7a\",\"cmd\":\"dao logMessageDAO\",\"value\":{\"cla