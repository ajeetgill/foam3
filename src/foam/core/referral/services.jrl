
p({
  "class": "foam.core.boot.CSpec",
  "name": "referralCodeDAO",
  "serve": true,
  "authenticate": true,
  "serviceScript":
  """
  return new foam.dao.EasyDAO.Builder(x)
    .setFuid(true)
    .setJournalName("referralCodes")
    .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
    .setOf(foam.core.referral.ReferralCode.getOwnClassInfo())
    .build()
    .addPropertyIndex(new foam.lang.PropertyInfo[] { foam.core.referral.ReferralCode.CUSTOM_REFERRAL_CODE });
  """,
  "client": """
  {
    "of": "foam.core.referral.ReferralCode"
  }
  """
})