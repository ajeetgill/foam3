p({
  class: "foam.core.ruler.Rule",
  id: "foam-core-notification-email-EmailMessagePropertyServiceRule",
  name: "EmailMessage EmailPropertyService",
  ruleGroup: "EmailMessage",
  daoKey: "localEmailMessageDAO",
  priority: 1000,
  operation: 3,
  predicate: {
    class: "foam.mlang.predicate.And",
    args: [
      {
        class: "foam.core.ruler.predicate.PropertyEQValue",
        propName: "status",
        propValue:  {
          class: "foam.core.notification.email.Status",
          ordinal: 0
        }
      }
    ]
  },
  action: {
    class: "foam.core.notification.email.EmailMessagePropertyServiceRuleAction",
  },
  enabled: true,
  lifecycleState:1
})

p({
  class: "foam.core.ruler.Rule",
