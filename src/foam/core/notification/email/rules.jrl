p({
  class: "foam.core.ruler.Rule",
  id: "foam-core-notification-email-EmailMessageProcessedStatusRule",
  name: "EmailMessage Status - Processed",
  documentation: "Move Processed EmailMessages to EmailMesageProcessedDAO",
  ruleGroup: "EmailMessage",
  daoKey: "localEmailMessageReceivedDAO",
  priority: 0,
  operation: 3,
  predicate: {
    class: "foam.mlang.predicate.And",
    args: [
      {
        class: "foam.core.ruler.predicate.PropertyEQValue",
        propName: "status",
        propValue:  {
          class: "foam.core.notification.email.Status",
          ordinal: 6
        }
      }
    ]
  },
  action: {
    class: "foam.core.ruler.action.DAOPutRuleAction",
    daoKey: "emailMessageProcessedDAO"
  },
  enabled: true,
  lifecycleState:1
})
