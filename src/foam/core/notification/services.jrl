// not lazy as needed by notification system during startup.
p({
  "class": "foam.core.boot.CSpec",
  "name": "localNotificationDAO",
  "lazy": false,
  "serviceScript": """
    mdao = new foam.dao.MDAO(foam.core.notification.Notification.getOwnClassInfo());
    mdao.addIndex(new foam.lang.PropertyInfo[] { foam.core.notification.Notification.GROUP_ID,foam.core.notification.Notification.READ });
    mdao.addIndex(new foam.lang.PropertyInfo[] { foam.core.notification.Notification.BROADCASTED,foam.core.notification.Notification.READ });
    mdao.addIndex(new foam.lang.PropertyInfo[] { foam.core.notification.Notification.USER_ID,foam.core.notification.Notification.READ });
    mdao.addIndex(new foam.lang.PropertyInfo[] { foam.core.notification.Notification.EXPIRY_DATE });
    mdao.addIndex(new foam.lang.PropertyInfo[] { foam.core.notification.Notification.CREATED });

    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.notification.Notification.getOwnClassInfo())
      .setMdao(mdao)
      .setAuthorize(false)
      .setPm(true)
      .setFuid(true)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("notifications")
      .setSAF(true)
      .setWaitReplay(false)
      .setFixedSize(new foam.dao.FixedSizeDAO.Builder(x)
        .setComparator(foam.mlang.MLang.COMPOUND(new foam.mlang.order.Comparator[] {
          foam.mlang.MLang.DESC(foam.core.notification.Notification.CREATED),
          foam.core.notification.Notification.READ
        }))
        .setSize(100000)
        .build())
      .build();
  """
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "notificationDAO",
  "lazy": false,
  "serve": true,
  "serviceScript": """
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.notification.Notification.getOwnClassInfo())
      .setAuthorize(true)
      .setInnerDAO((foam.dao.DAO) x.get("localNotificationDAO"))
      .setDecorator(
        new foam.core.notification.NotificationTemplateDAO.Builder(x)
          .setDelegate(new foam.core.notification.NotificationExpansionDAO.Builder(x)
            .setDelegate(new foam.dao.NullDAO(x, foam.core.notification.Notification.getOwnClassInfo()))
            .build())
          .build())
      .setEnableInterfaceDecorators(false)
      .setOrder(new foam.mlang.order.Comparator[] {
        new foam.mlang.order.Desc.Builder(x).setArg1(foam.core.notification.Notification.CREATED).build()
      })
      .build();
""",
  "client": "{\"of\":\"foam.core.notification.Notification\"}"
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "userNotificationDAO",
  "serve": false,
  "serviceScript": """
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.notification.Notification.getOwnClassInfo())
      .setDecorator(new foam.core.notification.UserNotificationDAO(x, new foam.dao.NullDAO(x, foam.core.notification.Notification.getOwnClassInfo())))
      .setEnableInterfaceDecorators(false)
      .setNullify(true)
      .build();
  """
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "myNotificationDAO",
  "lazy": false,
  "serve": true,
  "serviceScript": """
    import foam.core.auth.User;
    import foam.core.auth.Subject;
    import foam.core.notification.Notification;

    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.notification.Notification.getOwnClassInfo())
      .setAuthorize(false)
      .setDecorator( new foam.core.notification.MyNotificationDAO.Builder(x).build() )
      .setInnerDAO((foam.dao.DAO) x.get("notificationDAO"))
      .setEnableInterfaceDecorators(false)
      .build();
  """,
  "client": """
    {
      "of": "foam.core.notification.Notification",
      "cache": true,
      "pollingInterval": 25000,
      "pollingProperty": {
        "class":"__Property__",
        "forClass_":"foam.core.notification.Notification",
        "name":"created"
      },
      "ttlPurgeTime": 0,
      "ttlSelectPurgeTime": 0,
      "decorators": [
        {
          "class":"foam.core.notification.ToastNotificationDAO"
        }
      ]
    }
  """
})

p({
  "class":"foam.core.boot.CSpec",
  "name":"notificationTemplateDAO",
  "lazy":false,
  "serve":true,
  "serviceScript":"""
    return new foam.dao.EasyDAO.Builder(x)
      .setPm(true)
      .setSeqNo(true)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("notificationTemplates")
      .setOf(foam.core.notification.Notification.getOwnClassInfo())
      .build()
      .addPropertyIndex(new foam.lang.PropertyInfo[] {foam.core.notification.Notification.TEMPLATE});
    """,
    "client":"{\"of\":\"foam.core.notification.Notification\"}"
})

