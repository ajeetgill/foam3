p({
  "class": "foam.core.boot.CSpec",
  "name": "resendNotificationService",
  "serve": true,
  "authenticate": true,
  "boxClass":"foam.core.notification.ResendNotificationServiceInterfaceSkeleton",
  "serviceClass": "foam.core.notification.ResendNotificationService",
  "client":
    """
      {
        "class":"foam.core.notification.ClientResendNotificationService",
        "delegate": {
          "class":"foam.box.SessionClientBox",
          "delegate": {
            "class":"foam.box.HTTPBox",
            "url":
            "service/resendNotificationService"
          }
        }
      }
    """
})

