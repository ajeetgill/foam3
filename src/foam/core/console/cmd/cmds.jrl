p({
  "class":"foam.core.console.cmd.Command",
  "id": "clock",
  "description": "Insert a Clock",
  "script": """
    var clock = foam.demos.clock.Clock.create({x:110, y:110}, this);
    this.out.add(clock);
    this.currentBlock.value = clock;
   """
})

p({"class":"foam.core.console.cmd.Command", "id": "signature", "description": "Insert a Signature Block",  "script": """var s = foam.core.console.Signature.create({label: args[0] || ''}, this); this.out.add(s); this.currentBlock.value = s;"""})

p({"class":"foam.core.console.cmd.Command", "id": "check", "description": "Insert a checkmark",  "script": """var s = foam.core.console.Check.create({label: args[0] || ''}, this); this.out.add(s); this.currentBlock.value = s;"""})

p({"class":"foam.core.console.cmd.Command", "id": "now", "description": "Insert a timestamp",  "script": """var d = new Date(); var holder = foam.lang.DateTimeHolder.create({value: d}); this.currentBlock.value = holder; this.out.add(holder.value$);"""})

p({"class":"foam.core.console.cmd.Command", "id": "today", "description": "Insert today's date",  "script": """var d = new Date(); var holder = foam.lang.DateHolder.create({value: d}); this.currentBlock.value = holder; this.out.add(holder.value$.map(d => d.toDateString()));"""})

p({
  "class":"foam.core.console.cmd.Command",
  "id": "h",
  "description": "Insert a Header",
  "script": """addValue(foam.core.console.Header.create({text: args.join(' ')}, this));"""
})
p({
  "class":"foam.core.console.cmd.Command",
  "id": "h1",
  "description": "Header 1",
  "script": "addValue(foam.core.console.Header.create({type:'h1', text: args.join(' ')}, this));"
})
