p({
  "class": "foam.core.boot.CSpec",
  "name": "consoleZACClient",
  "authenticate": false,
  "lazyClient": true,
  "serve": true,
  "client":"""{"class":"foam.core.console.ConsoleZACClient"}"""
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "modelDAO",
  "authenticate": false,
  "lazyClient": true,
  "serve": true,
  "client":"""{"class":"foam.core.console.ModelDAO"}"""
})

p({
  "class":"foam.core.boot.CSpec",
  "name":"flowDAO",
  "description": "Stores FLOWs.",
  "serve":true,
  "authenticate":false,
  "serviceScript":
  """
    return new foam.dao.EasyDAO.Builder(x)
      .setPm(true)
      .setAuthorize(false)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("flows")
      .setOf(foam.core.console.Flow.getOwnClassInfo())
      .build();
  """,
  "client":"""{"of":"foam.core.console.Flow"}"""
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "agentDAO",
  "description": "Stores SinkVeiw Agents",
  "serve":true,
  "authenticate":false,
  "serviceScript":
  """
    return new foam.dao.EasyDAO.Builder(x)
      .setPm(true)
      .setAuthorize(false)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("agents")
      .setOf(foam.core.console.SinkAgent.getOwnClassInfo())
      .build();
  """,
  "client":"""{"of":"foam.core.console.SinkAgent"}"""
})