p({
  class: "foam.core.menu.Menu",
  id: "foam.core.alarming.alarmWidget",
  label: "Alarms",
  handler: {
    class: "foam.core.menu.ViewMenu",
    view: {
      class: "foam.dashboard.view.CardWrapper",
      title: "Alarms",
      currentView: {
        class: "foam.dashboard.view.DAOTable",
        dao: "alarmDAO",
        predicate: {
          class: "foam.mlang.predicate.FScriptPredicate",
          query: 'isActive==true&&(severity==foam.log.LogLevel.ERROR || severity==foam.log.LogLevel.WARN)'
        },
        limit: 4,
        citationView: "foam.core.alarming.AlarmCitationView",
        viewMore: true,
        emptyTitle: "No activity"
      },
      mode: "config"
    }
  },
  parent:"hidden"
})
