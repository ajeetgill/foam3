  """
    return new foam.core.auth.AuthorizationDAO.Builder(x)
      .setDelegate((foam.dao.DAO) x.get("localServiceProviderDAO"))
      .setAuthorizer(new foam.core.auth.StandardAuthorizer("serviceprovider"))
      .build();
  """,
  "client":"{\"of\":\"foam.core.auth.ServiceProvider\"}"
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "localUserDAO",
  "serve": false,
  "serviceScript": """
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.auth.User.getOwnClassInfo())
      .setPm(true)
      .setFuid(true)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("users")
      .setDecorator(new foam.core.auth.UserPasswordHashingDAO(x, new foam.dao.NullDAO(x, foam.core.auth.User.getOwnClassInfo())))
      .build()
      .addPropertyIndex(new foam.lang.PropertyInfo[] { foam.core.auth.User.REFERRAL_CODE });
  """
})

p({
  "class":"foam.core.boot.CSpec",
  "name":"userDAO",
  "serve":true,
  "serviceScript":"""
    return new foam.dao.EasyDAO.Builder(x)
      .setPm(true)
      .setInnerDAO(x.get("localUserDAO"))
      .setOf(foam.core.auth.User.getOwnClassInfo())
      .setPermissioned(true)
      .setDecorator(
        new foam.dao.ValidatingDAO(x,
          new foam.core.auth.UserLifecycleStateDAO(x,
            new foam.dao.NullDAO(x, foam.core.auth.User.getOwnClassInfo())),
          new foam.core.auth.validators.UserGroupAndSpidValidator()
        )
      )
      .build();
  """,
  "client":"""
    {
      "of":"foam.core.auth.User",
      "ttlSelectPurgeTime": 15000,
      "ttlPurgeTime": 0,
      "decorators": [{"class":"foam.core.fs.FileDAODecorator"}]
    }
  """
})


p({
  "class":"foam.core.boot.CSpec",
  "name":"localUserUserDAO",
  "description":"A filter on localUserDAO that filters out all subclasses of User.",
  "authenticate": false,
  "serviceScript":
  """
    // Filter in other projects which create new User types.
    return x.get("localUserDAO");
  """
})


p({
  "class": "foam.core.boot.CSpec",
  "name": "uniqueUserService",
  "serve": true,
  "authenticate": true,
  "boxClass": "foam.core.auth.UniqueUserServiceSkeleton",
  "serviceScript": """
    x = x.put("localUserDAO", x.get("localUserDAO")
      .where(foam.mlang.MLang.NEQ(foam.core.auth.User.LIFECYCLE_STATE, foam.core.auth.LifecycleState.DELETED)));
    ul = new foam.core.auth.PreventDuplicateEmailLoginService(x);
    ul = new foam.core.auth.FilterBySpidService.Builder(x)
      .setDelegate(ul)
      .build();
    return ul;
  """
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "userQueryService",
  "serve": true,
  "serviceClass": "foam.core.auth.SimpleUserQueryService",
  "boxClass": "foam.core.auth.UserQueryServiceSkeleton",
  "client":
  """
    {
      "class":"foam.core.auth.ClientUserQueryService",
      "delegate": {
        "class":"foam.box.SessionClientBox",
        "delegate": {
          "class":"foam.box.HTTPBox",
          "url":
          "service/userQueryService"
        }
      }
    }
  """
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "userRegistrationDAO",
  "lazy": false,
  "serve": true,
  "authenticate": false,
  "authNotes": "UserRegistrationDAO disables find, select and remove operations.",
  "serviceScript":
  """
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.auth.User.getOwnClassInfo())
      .setInnerDAO(x.get("localUserDAO"))
      .setDecorator(
        new foam.core.auth.UserRegistrationSanitationDAO(x,
        new foam.core.auth.UserRegistrationDAO(x,
        new foam.dao.ValidatingDAO(x,
          new foam.dao.NullDAO(x,foam.core.auth.User.getOwnClassInfo()),
          new foam.core.auth.validators.UserGroupAndSpidValidator()
        ))))
      .setAuthorize(false)
      .setRuler(true)
      .setPm(true)
      .setEnableInterfaceDecorators(false)
      .build();
  """,
  "client": """
    {
      "of": "foam.core.auth.User",
      "cache": true,
      "retryBoxMaxAttempts": 0
    }
  """
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "loginAttemptDAO",
  "serve": true,
  "description": "Keep track of login attempts made by users.",
  "serviceScript":
  """
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.auth.LoginAttempt.getOwnClassInfo())
      .setFuid(true)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("loginattempts")
      .setFixedSize(new foam.dao.FixedSizeDAO.Builder(x)
        .setComparator(foam.mlang.MLang.DESC(foam.core.auth.LoginAttempt.CREATED))
        .setSize(10000)
        .build())
      .setOrder(new foam.mlang.order.Comparator[] { new foam.mlang.order.Desc.Builder(x).setArg1(foam.core.auth.LoginAttempt.CREATED).build() })
      .build()
      .addPropertyIndex(new foam.lang.PropertyInfo[] {foam.core.auth.LoginAttempt.CREATED});
  """,
  "client": """
    {
      "of": "foam.core.auth.LoginAttempt"
    }
  """
})
