p({
  "class": "foam.core.boot.CSpec",
  "name": "agentJunctionDAO",
  "lazy": false,
  "serve": true,
  "description": "DAO responsible for storing agent authentication permission information.",
  "serviceScript": """
    return new foam.dao.EasyDAO.Builder(x)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName(\"agentJunctions\")
      .setOf(foam.core.auth.UserUserJunction.getOwnClassInfo())
      .build();
  """,
  "client": "{\"of\":\"foam.core.auth.UserUserJunction\", \"remoteListenerSupport\": false}"
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "localCountryDAO",
  "description": "A DAO which contains information about countries.",
  "serve": false,
  "authenticate": false,
  "serviceScript": """
    return new foam.dao.EasyDAO.Builder(x)
      .setPm(true)
      .setAuthorizer(new foam.core.auth.GlobalReadAuthorizer("country"))
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("countries")
      .setOf(foam.core.auth.Country.getOwnClassInfo())
      .setOrder(new foam.lang.PropertyInfo[] {foam.core.auth.Country.NAME})
      .build()
      .addPropertyIndex(new foam.lang.PropertyInfo[] { foam.core.auth.Country.ISO31661CODE })
      .addPropertyIndex(new foam.lang.PropertyInfo[] { foam.core.auth.Country.ALTERNATIVE_NAMES });
  """
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "countryDAO",
  "serve": true,
  "authenticate": false,
  "serviceScript":
  """
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.auth.Country.getOwnClassInfo())
      .setName("countries")
      .setAuthorizer(new foam.core.auth.GlobalReadAuthorizer("country"))
      .setInnerDAO(x.get("localCountryDAO"))
      .build();
  """,
  "client":
  """
    {
      "of": "foam.core.auth.Country",
      "cache": true,
      "ttlSelectPurgeTime": 0,
      "ttlPurgeTime": 0
    }
  """,
  "authNotes": "The \"authenticate\" flag is explicitly set to false because we want to be able to use the countryDAO to populate a dropdown in the sign up form. The DAO is decorated with an AuthorizationDAO decorator with \"authorizeOnRead\" set to false so that anyone can read from countryDAO but only those with permission can write to or remove from it."
})

