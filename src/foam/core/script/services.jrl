p({
  "class":"foam.core.boot.CSpec",
  "name":"scriptDAO",
  "serve":true,
  "serviceScript":"""
    mdao = new foam.dao.MDAO(foam.core.script.Script.getOwnClassInfo());
    mdao.addIndex(new foam.lang.PropertyInfo[] {foam.core.script.Script.LAST_RUN});
    mdao.addIndex(new foam.lang.PropertyInfo[] {foam.core.script.Script.ENABLED});
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.script.Script.getOwnClassInfo())
      .setMdao(mdao)
      .setGuid(true)
      .setPm(true)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("scripts")
      .setDecorator(new foam.core.script.ScriptRunnerDAO(new foam.dao.NullDAO(x, foam.core.script.Script.getOwnClassInfo())))
      .setOrder(new foam.mlang.order.Comparator[] {
        new foam.mlang.order.Desc.Builder(x).setArg1(foam.core.script.Script.ENABLED).build(),
        new foam.mlang.order.Desc.Builder(x).setArg1(foam.core.script.Script.LAST_RUN).build()
      })
      .build();
  """,
  "client":"""
    {
      "of":"foam.core.script.Script",
      "cache":false
    }
  """
})

p({
  "class":"foam.core.boot.CSpec",
  "name":"scriptEventDAO",
  "serve":true,
  "serviceScript":"""
    mdao = new foam.dao.MDAO(foam.core.script.ScriptEvent.getOwnClassInfo());
    mdao.addIndex(new foam.lang.PropertyInfo[] {foam.core.script.ScriptEvent.OWNER});
    mdao.addIndex(new foam.lang.PropertyInfo[] {foam.core.script.ScriptEvent.LAST_RUN});
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.script.ScriptEvent.getOwnClassInfo())
      .setMdao(mdao)
      .setGuid(true)
      .setAuthorizer(new foam.core.auth.GlobalReadAuthorizer("scriptEvent"))
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("scriptEvents")
      .setWriteOnly(true)
      .setFixedSize(new foam.dao.FixedSizeDAO.Builder(x)
        .setComparator(foam.mlang.MLang.DESC(foam.core.script.ScriptEvent.LAST_RUN))
        .setSize(10000)
        .build())
      .setOrder(new foam.mlang.order.Comparator[] { new foam.mlang.order.Desc.Builder(x).setArg1(foam.core.script.ScriptEvent.LAST_RUN).build() })
      .setRuler(false)
      .setCluster(false)
      .setSaf(false)
      .build();
  """,
  "client":"{\"of\":\"foam.core.script.ScriptEvent\"}"
})

p({
  "class":"foam.core.boot.CSpec",
  "name":"scriptParameterDAO",
  "serve":true,
  "serviceScript":"""
    return new foam.dao.EasyDAO.Builder(x)
      .setOf(foam.core.script.ScriptParameter.getOwnClassInfo())
      .setGuid(true)
      .setPm(true)
      .setAuthorizer(new foam.core.auth.GlobalReadAuthorizer("scriptParameter"))
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("scriptparameters")
      .setOrder(new foam.mlang.order.Comparator[] {
        new foam.mlang.order.Desc.Builder(x).setArg1(foam.core.script.ScriptParameter.NAME).build(),
        new foam.mlang.order.Desc.Builder(x).setArg1(foam.core.script.ScriptParameter.DATE).build()
      })
      .build()
      .addPropertyIndex(new foam.lang.PropertyInfo[] { foam.core.script.ScriptParameter.NAME })
      .addPropertyIndex(new foam.lang.PropertyInfo[] { foam.core.script.ScriptParameter.DATE });
  """,
  "client":"""
    {
      "of":"foam.core.script.ScriptParameter",
      "cache":false
    }
  """
})
