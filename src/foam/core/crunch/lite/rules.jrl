  "class":"foam.core.ruler.Rule",
  "id":"bef37ddd-39ed-49be-8770-2e40b410858c",
  "name":"ApprovalRequest update assignedTo",
  "priority":150,
  "ruleGroup":"approvals",
  "documentation":"Handle a change to assignedTo",
  "daoKey":"approvalRequestDAO",
  "operation":3,
