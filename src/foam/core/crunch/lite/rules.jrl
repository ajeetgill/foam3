p({
  "class":"foam.core.ruler.Rule",
  "id":"2cc4d97d-a962-48a2-9b58-09da267f760a",
  "name":"ApprovalRequest update memo",
  "priority":150,
  "ruleGroup":"approvals",
  "documentation":"Handle a change to memo",
  "daoKey":"approvalRequestDAO",
  "operation":3,
  "after":true,
  "predicate":{
    "class":"foam.mlang.predicate.And",
    "args":[
      {
        "class":"foam.core.ruler.predicate.PropertyEQValue",
        "propName":"status",
        "propValue":{
          "class":"foam.core.approval.ApprovalStatus",
          "ordinal":0
        }
      },
      {
        "class":"foam.core.ruler.predicate.PropertyChangePredicate",
        "propName":"memo"
      }
    ]
  },
  "action":{
    "class":"foam.core.approval.ApprovalRequestMemoRule"
  },    
  "enabled":true,
  "saveHistory":false,
  "lifecycleState":1
})

p({
  "class":"foam.core.ruler.Rule",
  "id":"68afcf0c-c718-98f8-0841-75e97a3ad16d175",
  "name":"approvableDAO Approve or Reject",
  "priority":110,
  "ruleGroup":"approvables",
  "documentation":"Handle an approved or rejected generic approvable",
  "daoKey":"approvableDAO",
  "operation":1,
  "predicate":{
    "class":"foam.mlang.predicate.And",
    "args":[
      {
        "class": "foam.mlang.predicate.Not",
        "arg1": {
          "class": "foam.mlang.predicate.IsInstanceOf",
          "of": "foam.core.approval.CompositeApprovable"
        }
      },
      {
        "class":"foam.core.approval.FulfilledApprovablePredicate",
      }
    ]
  },
  "action":{
    "class":"foam.core.approval.FulfilledApprovableRule"
  },
  "enabled":true,
  "saveHistory":true,
  "lifecycleState":1
})

p({
  "class":"foam.core.ruler.Rule",
  "id":"b4162f62-b474-48b2-8940-0359a6f9b555",
  "name":"approvableDAO Composite Approve or Reject",
  "priority":110,
  "ruleGroup":"approvables",
  "documentation":"Handle an approved or rejected composite approvable",
  "daoKey":"approvableDAO",
  "operation":1,
  "predicate":{
