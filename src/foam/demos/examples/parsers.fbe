log('StringPStream:', p.parse(sps));

var erps = foam.parse.ErrorReportingPStream.create({
  delegate: P.stringPStream('1+2*(1+2')
});

var res = p.parse(erps, p);
log('ErrorReportingPStream:', res);
log(erps);
*/