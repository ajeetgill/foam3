p({
  "class":"foam.core.boot.CSpec",
  "name":"exportDriverRegistryDAO",
  "description": "DAO which provides a reference to data type drivers which are used to export data in various types",
  "serve":true,
  "serviceScript":
  """
    return new foam.dao.EasyDAO.Builder(x)
      .setPm(true)
      .setAuthorize(true)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("exportDriverRegistrys")
      .setDecorator(new foam.dao.EnabledAwareDAO.Builder(x).setOf(foam.core.export.ExportDriverRegistry.getOwnClassInfo()).build())
      .setOf(foam.core.export.ExportDriverRegistry.getOwnClassInfo())
      .build();
  """,
  "client":"""{"of":"foam.core.export.ExportDriverRegistry","cache":true,"ttlSelectPurgeTime":0,"ttlPurgeTime":0}"""
})

p({
  "class": "foam.core.boot.CSpec",
  "name": "menuDAO",
  "serve": true,
  "authenticate": false,
  "serviceScript":
  """
    return new foam.dao.EasyDAO.Builder(x)
      .setName("menu")
      .setPm(true)
      .setJournalType(foam.dao.JournalType.SINGLE_JOURNAL)
      .setJournalName("menus")
      .setOf(foam.core.menu.Menu.getOwnClassInfo())
      .setOrder(new foam.lang.PropertyInfo[] {foam.core.menu.Menu.ORDER, foam.core.menu.Menu.LABEL})
      .build();
  """,
  "client": """
    {
      "of": "foam.core.menu.Menu",
      "order": [
        {
          "class": "__Property__",
          "forClass_": "foam.core.menu.Menu",
          "name": "order"
        },
        {
          "class": "__Property__",
          "forClass_": "foam.core.menu.Menu",
          "name": "label"
        }
      ],
      "cache": true,
      "ttlSelectPurgeTime": 0,
      "ttlPurgeTime": 0
    }
  """
})

