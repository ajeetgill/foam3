p({
  "class":"foam.core.test.Test",
  "id":"MultiLineOutput",
  "code":
  """
    storage = x.get(foam.core.fs.FileSystemStorage.class);
    file = java.io.File.createTempFile(\"temp\", null, storage.get("."));
    file.deleteOnExit();
    outputter = new foam.lib.json.Outputter(x, file);
    string = \"\\\\\\t line1 \\n   \\\\n  \\n line2 \\n line3 \\\" \\\\ \";
    user = new foam.core.auth.User(x);
    user.setId(24);
    user.setFirstName(string);
    user.setLastName(\"Fjorenborenborkenberger\");
    outputter.setMultiLine(true);
    outputter.outputJSONJFObject((foam.lang.FObject) user);
    outputter.flush();

    storageX = x.put(foam.core.fs.Storage.class, storage);
    filejournal = new foam.dao.FileJournal(storageX);
    filejournal.setMultiLineOutput(true);
    filejournal.setFilename(file.getName());
    firstread = filejournal.getEntry(filejournal.getReader());
    firstread = firstread.substring(2, firstread.length() - 1);
    parser = new foam.lib.json.JSONParser();
    firstparse = parser.parseString(firstread);
    outputter.outputJSONJFObject((foam.lang.FObject) firstparse);
    secondread = filejournal.getEntry(filejournal.getReader());
    secondread = secondread.substring(2, secondread.length() - 1);
    test(firstread.equals(secondread), \"Reparsing preserves JSON\");
  """,
  "output":""
})
p({"class":"foam.test.AddressUtilTests","id":"AddressUtilAddressParsingTest"})
p({
  "class":"foam.core.test.Test",
  "id":"ClientAddressUtilAddressParsingTest",
  "server":false,
  "code":"""
  function testAddressParse(address1, address2, number, street) {
    var addrs1 = foam.util.AddressUtil.parseAddress(address1, address2);
    test(addrs1[0] === number && addrs1[1] === street, "[" + address1 + (address2 ? "," + address2 : "") + "] parsed to [" + number + ", " + street + "]");
  }

  testAddressParse("14 Cheltenham Mews", "", "14", "Cheltenham Mews");
  testAddressParse("25 St. Dennis Drive", "Suite # 1019", "25", "St. Dennis Drive");
  testAddressParse("1505 - 25 The Esplanade", "", "25", "The Esplanade");
  testAddressParse("1505-19 Western Battery Rd", "", "19", "Western Battery Rd");
  """
})
